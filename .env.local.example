# Tutorial Clarity - Environment Variables
# ==========================================
# Copy this file to .env.local and replace the placeholder values with your real API keys.
#
#   PowerShell:  Copy-Item .env.local.example .env.local
#   Then edit .env.local with your real keys.
#
# Without OPENAI_API_KEY, the Clarify Audio feature will fall back to robotic
# browser voices (speechSynthesis) instead of natural-sounding OpenAI TTS.
# Get your key at: https://platform.openai.com/api-keys

OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
