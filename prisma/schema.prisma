generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  clerkId         String        @unique
  email           String        @unique
  createdAt       DateTime      @default(now())
  referredByCode  String?
  subscription    Subscription?
  usageRecords    UsageRecord[]
}

model Affiliate {
  id              String       @id @default(cuid())
  code            String       @unique
  name            String
  email           String?
  address         String?
  phone           String?
  website         String?
  stripeAccountId String?      // Stripe Connect Express account ID
  status          String       @default("pending_stripe") // pending_stripe | active | suspended
  createdAt       DateTime     @default(now())
  commissions     Commission[]
}

model Commission {
  id               String    @id @default(cuid())
  affiliateCode    String
  affiliate        Affiliate @relation(fields: [affiliateCode], references: [code])
  userId           String
  stripeInvoiceId  String    @unique
  amountCents      Int       // 30% of invoice amount in cents
  status           String    @default("pending") // pending | paid
  createdAt        DateTime  @default(now())
  paidAt           DateTime?

  @@index([affiliateCode, status])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id])
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("trial") // trial | monthly | annual | free
  status               String    @default("active") // active | canceled | past_due
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  sessionsUsed         Int       @default(0)
  bonusSessions        Int       @default(0)
  sessionsResetAt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  feature   String   // clarify_audio | summary | transcript | definition
  videoId   String
  createdAt DateTime @default(now())

  @@index([userId, feature, createdAt])
}

model SavedVideo {
  id           String   @id  // YouTube video ID
  url          String
  title        String
  dateSaved    DateTime @default(now())
  isPersistent Boolean  @default(false)
}
